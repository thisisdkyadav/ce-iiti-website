PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:4000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=cewebsite

# Used only once to seed the first admin user when admin_users is empty.
ADMIN_BOOTSTRAP_PASSWORD=admin123
ADMIN_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Session and uploads configuration.
ADMIN_SESSION_TTL_DAYS=7
ADMIN_SESSION_COOKIE_NAME=ce_admin_session
UPLOADS_DIRECTORY_PATH=../public/uploads
UPLOADS_MAX_IMAGE_SIZE_BYTES=5242880
